table = {
   ('A' , 'Dirty'): 'Suck',
   ('A' , 'Clean'): ' Move Right',
  
   ('B' , 'Dirty'): 'Suck',
   ('B' , 'Clean'): 'Move Forward',


   ('C' , 'Dirty'): 'Suck',
   ('C' , 'Clean'): 'Move Backward',


   ('D' , 'Dirty'): 'Suck',
   ('D' , 'Clean'): 'Move Left'
}


sequence_table = {
   (('A' , 'Dirty') , ('A' , 'Clean')): 'Move Right',
   (('A' , 'Clean') , ('A' , 'Dirty')): 'Suck',
   (('B' , 'Dirty') , ('B' , 'Clean')): 'Move Forward',
   (('B' , 'Clean') , ('B' , 'Dirty')): 'Suck',
   (('C' , 'Dirty') , ('C' , 'Clean')): 'Move Backward',
   (('C' , 'Clean') , ('C' , 'Dirty')): 'Suck',
   (('D' , 'Dirty') , ('D' , 'Clean')): 'Move Left',
   (('D' , 'Clean') , ('D' , 'Dirty')): 'Suck'
}


percepts = []


def table_driven_agent(percept):
   percepts.append(percept)


   if tuple(percepts) in sequence_table:
       return sequence_table[tuple(percepts)]
  
   return table.get(percept , "No Operation")


print("Vaccum Cleaner Table-Driven Agent")


n = int(input("Enter no.of Percepts: "))


for i in range(n):
   print(f"\nPercept {i + 1}")


   location = input("Enter Location (A/B/C/D): ").upper()
   status = input("Enter Status (Clean/Dirty): ").capitalize()


   percept = (location , status)
   action = table_driven_agent(percept)


   print("Percept History: ",percepts)
   print("Agent Action: ",action)

