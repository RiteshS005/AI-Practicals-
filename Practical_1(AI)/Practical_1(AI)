   ('D', 'Red', 'Yes', 'No'): 'Stop',
   ('D', 'Green', 'Yes', 'Yes'): 'Drop Passenger'
}


percepts = []


def taxi_agent(percept):
   percepts.append(percept)
   action = table.get(percept, "Wait")
   return action


print("Autonomous Taxi Table-Driven Agent")


